RewriteEngine on


RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R]

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [NC,L]

RewriteCond %{HTTP_HOST} ^www.jhperformance.fi [OR]
RewriteCond %{HTTP_HOST} ^jhperformance.fi [NC]
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://www.jhperformance.fi/$1 [R=301,L]